{
  "_key": "cs-initial-access",
  "name": "Initial Access via SCP/SSH",
  "description": "Copy beacon payload to target via SCP then execute via SSH to establish initial foothold",
  "executionType": "cobalt_strike",
  "estimatedDuration": 30,
  "inputs": [
    {
      "id": "payload_ready",
      "label": "Payload Ready",
      "type": "boolean",
      "required": true
    },
    {
      "id": "signal",
      "label": "Signal",
      "type": "signal",
      "required": false,
      "description": "Optional signal from upstream node"
    }
  ],
  "outputs": [
    {
      "id": "session",
      "label": "Initial Beacon",
      "type": "session",
      "description": "First beacon from target"
    }
  ],
  "parameters": [
    {
      "id": "targetIp",
      "label": "Target IP",
      "type": "string",
      "required": true,
      "placeholder": "172.16.2.5",
      "default": "172.16.2.5"
    },
    {
      "id": "targetUser",
      "label": "Target User",
      "type": "string",
      "required": true,
      "placeholder": "Administrator",
      "default": "Administrator"
    },
    {
      "id": "targetPass",
      "label": "Target Pass",
      "type": "string",
      "required": true,
      "placeholder": "P@ssw0rd",
      "default": "P@ssw0rd"
    }
  ],
  "requirements": {
    "c2Server": true,
    "listeners": [
      "HTTP"
    ],
    "payloads": [
      "update"
    ],
    "libraries": [
      "cobaltstrikec2/cobaltstrike.py",
      "SSHLibrary",
      "SCPLibrary"
    ]
  },
  "robotFramework": {
    "keyword": "Initial Access",
    "libraries": [
      "cobaltstrikec2/cobaltstrike.py",
      "SSHLibrary",
      "SCPLibrary"
    ],
    "keywordArgs": [
      {
        "param": "targetIp",
        "position": 1,
        "variableRef": true,
        "variableName": "TARGET1"
      },
      {
        "param": "targetUser",
        "position": 2,
        "variableRef": false
      },
      {
        "param": "targetPass",
        "position": 3,
        "variableRef": false
      },
      {
        "variableName": "LOCAL_INITIAL_BEACON",
        "position": 4,
        "variableRef": true
      }
