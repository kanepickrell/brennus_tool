        "fromParam": "targetIp",
        "scope": "suite"
      }
    ],
    "postKeywordStatements": [
      "@{_sessions}=    Get Sessions By IP    ${TARGET1}",
      "${CURRENT_SESSION}=    Set Variable    ${_sessions[0]}"
    ],
    "sessionVariable": "CURRENT_SESSION",
    "documentation": "SCP payload to target and execute via SSH",
    "tags": [
      "initial-access",
      "ssh"
