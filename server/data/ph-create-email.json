{
  "_key": "ph-create-email",
  "name": "Create Phishing Email",
  "tactic": "TA0001",
  "icon": "✉️",
  "description": "Build phishing email from template: rewrite body URL, set sender, subject, targets, and optional attachment",
  "executionType": "phishing",
  "estimatedDuration": 5,
  "inputs": [
    { "id": "signal", "label": "Signal", "type": "signal", "required": false }
  ],
  "outputs": [
    { "id": "emailReady", "label": "Email Ready", "type": "signal" }
  ],
  "parameters": [
    { "id": "hostIp",      "label": "HTTP Server IP",   "type": "string", "required": true,  "placeholder": "10.10.104.30",                   "default": "${HTTP_SERVER_IP}"   },
    { "id": "httpPort",    "label": "HTTP Server Port", "type": "number", "required": true,  "placeholder": "9008",                           "default": "${HTTP_SERVER_PORT}" },
    { "id": "sender",      "label": "Sender Address",   "type": "string", "required": true,  "placeholder": "it-support@company.com",          "default": "${PHISHING_SENDER}" },
    { "id": "targetList",  "label": "Target List",      "type": "string", "required": true,  "placeholder": "/home/bah/Projects/targets.txt", "default": "${TARGET_LIST_PATH}"},
    { "id": "emailHeader", "label": "Email Subject",    "type": "string", "required": true,  "placeholder": "Security Update Required",        "default": "${EMAIL_SUBJECT}"   },
    { "id": "emailBody",   "label": "Body HTML Path",   "type": "string", "required": true,  "placeholder": "/home/bah/Projects/body.html",   "default": "${BODY_HTML_PATH}"  },
    { "id": "attachment",  "label": "Attachment Path",  "type": "string", "required": false, "placeholder": "${EMPTY}",                        "default": "${EMPTY}"           },
    { "id": "payloadName", "label": "Payload Filename", "type": "string", "required": true,  "placeholder": "pca_update.exe",                  "default": "${PAYLOAD_NAME}"    }
  ],
  "requirements": {
    "c2Server": false,
    "libraries": ["phishing/PhishingLibrary.py"]
  },
  "robotFramework": {
    "keyword": "Create the Phishing Email",
    "libraries": ["phishing/PhishingLibrary.py"],
    "libraryArgs": [
      { "paramName": "smtp_cli_path", "globalSetting": "SMTP_CLI_PATH", "position": 1 }
    ],
    "keywordArgs": [
      { "param": "hostIp",      "variableRef": true, "variableName": "HTTP_SERVER_IP",   "position": 1 },
      { "param": "httpPort",    "variableRef": true, "variableName": "HTTP_SERVER_PORT",  "position": 2 },
      { "param": "sender",      "variableRef": true, "variableName": "PHISHING_SENDER",   "position": 3 },
      { "param": "targetList",  "variableRef": true, "variableName": "TARGET_LIST_PATH",  "position": 4 },
      { "param": "emailHeader", "variableRef": true, "variableName": "EMAIL_SUBJECT",     "position": 5 },
      { "param": "emailBody",   "variableRef": true, "variableName": "BODY_HTML_PATH",    "position": 6 },
      { "param": "attachment",  "variableRef": true, "variableName": "EMAIL_ATTACHMENT",  "position": 7 },
      { "param": "payloadName", "variableRef": true, "variableName": "PAYLOAD_NAME",      "position": 8 }
    ],
    "variables": [
      { "name": "HTTP_SERVER_IP",   "fromParam": "hostIp",      "default": "10.10.104.30",                   "scope": "suite" },
      { "name": "HTTP_SERVER_PORT", "fromParam": "httpPort",    "default": "9008",                           "scope": "suite" },
      { "name": "PHISHING_SENDER",  "fromParam": "sender",      "default": "it-support@company.com",         "scope": "suite" },
      { "name": "TARGET_LIST_PATH", "fromParam": "targetList",  "default": "/home/bah/Projects/targets.txt", "scope": "suite" },
      { "name": "EMAIL_SUBJECT",    "fromParam": "emailHeader", "default": "Security Update Required",       "scope": "suite" },
      { "name": "BODY_HTML_PATH",   "fromParam": "emailBody",   "default": "/home/bah/Projects/body.html",   "scope": "suite" },
      { "name": "EMAIL_ATTACHMENT", "fromParam": "attachment",  "default": "${EMPTY}",                       "scope": "suite" },
      { "name": "PAYLOAD_NAME",     "fromParam": "payloadName", "default": "pca_update.exe",                 "scope": "suite" }
    ],
    "isSuiteSetup": false,
    "preKeywordLog":  "=== Building Phishing Email: ${EMAIL_SUBJECT} → ${PHISHING_SENDER} ===",
    "postKeywordLog": "=== Phishing Email Constructed ===",
    "documentation": "Build phishing email and rewrite body HTML to point at live HTTP server",
    "tags": ["phishing", "initial-access", "email"]
  }
}