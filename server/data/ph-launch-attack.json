{
  "_key": "ph-launch-attack",
  "name": "Launch Phishing Attack",
  "tactic": "TA0001",
  "icon": "\ud83c\udfa3",
  "description": "Full phishing pipeline: build email from template and transmit in one step. Use this for single-node campaigns; wire ph-create-email \u2192 ph-send-email separately for multi-step control.",
  "executionType": "phishing",
  "estimatedDuration": 15,
  "inputs": [
    {
      "id": "signal",
      "label": "Signal",
      "type": "signal",
      "required": false
    }
  ],
  "outputs": [
    {
      "id": "sent",
      "label": "Attack Launched",
      "type": "signal"
    }
  ],
  "parameters": [
    {
      "id": "hostIp",
      "label": "HTTP Server IP",
      "type": "string",
      "required": true,
      "placeholder": "10.10.104.30",
      "default": "${HTTP_SERVER_IP}"
    },
    {
      "id": "httpPort",
      "label": "HTTP Port",
      "type": "number",
      "required": true,
      "placeholder": "9008",
      "default": "${HTTP_SERVER_PORT}"
    },
    {
      "id": "sender",
      "label": "Sender Address",
      "type": "string",
      "required": true,
      "placeholder": "it-support@company.com",
      "default": "${PHISHING_SENDER}"
    },
    {
      "id": "targetList",
      "label": "Target List",
      "type": "string",
      "required": true,
      "placeholder": "/home/bah/Projects/targets.txt",
      "default": "${TARGET_LIST_PATH}"
    },
    {
      "id": "emailHeader",
      "label": "Email Subject",
      "type": "string",
      "required": true,
      "placeholder": "Security Update Required",
      "default": "${EMAIL_SUBJECT}"
    },
    {
      "id": "emailBody",
      "label": "Body HTML Path",
      "type": "string",
      "required": true,
      "placeholder": "/home/bah/Projects/body.html",
      "default": "${BODY_HTML_PATH}"
    },
    {
      "id": "attachment",
      "label": "Attachment Path",
      "type": "string",
      "required": false,
      "placeholder": "${EMPTY}",
      "default": "${EMPTY}"
    },
    {
      "id": "payloadName",
      "label": "Payload Filename",
      "type": "string",
      "required": true,
      "placeholder": "pca_update.exe",
      "default": "${PAYLOAD_NAME}"
    },
    {
      "id": "emailServer",
      "label": "SMTP Server IP",
      "type": "string",
      "required": true,
      "placeholder": "10.0.0.25",
      "default": "${PHISHING_SERVER}"
    },
    {
      "id": "emailPort",
      "label": "SMTP Port",
      "type": "number",
      "required": true,
      "placeholder": "25",
      "default": "${PHISHING_PORT}"
    }
  ],
  "requirements": {
    "c2Server": false,
    "libraries": [
      "phishing/PhishingLibrary.py",
      "phishing/HTTPLibrary.py"
    ]
  },
  "robotFramework": {
