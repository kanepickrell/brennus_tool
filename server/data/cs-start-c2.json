    { "id": "csPass", "label": "CS Password",  "type": "string", "required": true,  "placeholder": "password",          "default": "${CS_PASS}" },
    { "id": "csDir",  "label": "CS Directory", "type": "string", "required": true,  "placeholder": "/opt/cobaltstrike", "default": "${CS_DIR}"  },
