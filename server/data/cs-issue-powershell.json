{
  "_key": "cs-issue-powershell",
  "name": "Run PowerShell Command",
  "description": "Run a PowerShell command on the active beacon session",
  "executionType": "cobalt_strike",
  "estimatedDuration": 5,
  "tactic": "TA0002",
  "icon": "⚡",
  "inputs": [
    { "id": "session", "label": "Beacon Session", "type": "session", "required": true }
  ],
  "outputs": [
    { "id": "session", "label": "Beacon Session", "type": "session", "description": "Session passed through" }
  ],
  "parameters": [
    {
      "id": "command",
