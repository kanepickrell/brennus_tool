      "default": "Get-Process"
    }
  ],
  "requirements": {
    "c2Server": true,
    "libraries": ["cobaltstrikec2/cobaltstrike.py"]
  },
  "robotFramework": {
    "keyword": "Issue Powershell Cmd",
    "libraries": ["cobaltstrikec2/cobaltstrike.py"],
    "captureOutput": "PS_OUTPUT",
    "variables": [
      { "name": "CURRENT_SESSION", "default": "0", "scope": "suite" },
      { "name": "PS_COMMAND", "fromParam": "command", "default": "Get-Process", "scope": "suite" }
    ],
    "keywordArgs": [
      { "param": "session", "position": 1, "sessionVariable": "CURRENT_SESSION" },
      { "param": "command", "position": 2, "variableRef": true, "variableName": "PS_COMMAND" }
    ],
    "preKeywordLog": "=== Running PowerShell on beacon: ${PS_COMMAND} ===",
    "postKeywordLog": "=== PowerShell complete ===",
    "documentation": "Run PowerShell command on active beacon",
    "tags": ["execution", "powershell", "beacon"]
