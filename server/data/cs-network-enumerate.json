{
  "_key": "cs-network-enumerate",
  "name": "Network Enumerate",
  "tactic": "TA0007",
  "icon": "🔍",
  "description": "Run portscan on target subnet via beacon",
  "executionType": "cobalt_strike",
  "estimatedDuration": 30,
  "inputs": [
    {
      "id": "session",
      "label": "Beacon Session",
      "type": "session",
      "required": true
    }
  ],
  "outputs": [
    {
      "id": "scan_results",
      "label": "Scan Results",
      "type": "string",
      "description": "Port scan output"
    }
  ],
  "parameters": [
    {
      "id": "session",
      "label": "Session",
      "type": "string",
      "required": true,
      "placeholder": "${CURRENT_SESSION}",
      "default": "${CURRENT_SESSION}"
    },
    {
      "id": "targetRange",
      "label": "Target Range",
      "type": "string",
      "required": true,
      "placeholder": "172.16.2.0/24",
      "default": "172.16.2.0/24"
    },
    {
      "id": "ports",
      "label": "Ports",
      "type": "string",
      "required": true,
      "placeholder": "445,5985,135",
      "default": "445,5985,135"
    },
    {
      "id": "method",
      "label": "Method",
      "type": "select",
      "required": true,
      "options": [
        "icmp",
        "arp"
      ],
      "default": "icmp"
    }
  ],
  "requirements": {
    "c2Server": true,
    "listeners": [],
    "payloads": [],
    "libraries": [
      "cobaltstrikec2/cobaltstrike.py"
    ]
  },
  "robotFramework": {
    "keyword": "Network Enumerate",
    "libraries": [
      "cobaltstrikec2/cobaltstrike.py"
    ],
    "keywordArgs": [
      {
        "param": "session",
        "position": 1,
        "sessionVariable": "CURRENT_SESSION"
      },
      {
        "param": "targetRange",
        "position": 2,
        "variableRef": false
      },
      {
        "param": "ports",
        "position": 3,
        "variableRef": false
      },
      {
        "param": "method",
        "position": 4,
        "variableRef": true,
        "variableName": "SCAN_METHOD"
      }
    ],
    "variables": [
      {
        "name": "SCAN_METHOD",
        "fromParam": "method",
        "default": "icmp",
        "scope": "suite"
      },
      {
        "name": "ARCH",
        "default": "x64",
        "scope": "suite"
      }
    ],
    "preKeywordLog": "=== Network Enumerate: ${targetRange} ===",
    "documentation": "Portscan target range via beacon",
    "tags": [
      "discovery",
      "portscan"
    ]
  }
}